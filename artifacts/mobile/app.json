{
  "expo": {
    "name": "3 Batti",
    "slug": "3-batti",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "3batti",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0C10"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.anuj.threebatti"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0A0C10"
      },
      "package": "com.anuj.threebatti",
      "versionCode": 1,
      "permissions": []
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "output": "static"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow 3 Batti to access your photos for UPI QR upload."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
